# =============================================================================
# CareerForge .gitignore
# Personal data, generated outputs, and build artefacts must never be committed.
# =============================================================================

# ── Private research (competitive analysis — never commit) ────────────────────
.reference/

# ── Candidate profile content (populated by /setup — personal data) ───────────
# In the FRAMEWORK repo, these are [UPPER_SNAKE_CASE] templates — tracked here.
# In a USER FORK, add these lines back to YOUR .gitignore to protect personal data:
#   .claude/skills/job-application-assistant/01-candidate-profile.md
#   .claude/skills/job-application-assistant/02-behavioral-profile.md
#   ... (and so on for all seven profile files)
# CLAUDE.md (Role B user profile) is always gitignored in user forks — see below.

# ── Workspace permissions (personal — REQ-6002) ───────────────────────────────
# The framework ships .claude/settings.local.json.template (tracked). The real
# settings.local.json is each user's private permission set — never commit it.
.claude/settings.local.json

# ── Application state (personal — changes per user) ───────────────────────────
job_search_tracker.csv
# Atomic-writer siblings created at repo root by the dashboard write layer.
# The .bak is a full copy of the personal tracker — never commit it.
.job_search_tracker.csv.tmp.*
.job_search_tracker.csv.bak
job_scraper/seen_jobs.json

# ── Salary data (user-provided, sensitive) ────────────────────────────────────
salary_data.json

# ── Generated documents (CV + cover letter outputs) ───────────────────────────
# Canonical /apply outputs (data-req §15): cv/main_<company>.{tex,pdf} and
# cover_letters/cover_<company>_<role>.{tex,pdf}. The example templates
# (main_example*, *.cls) stay tracked.
cv/main_*
!cv/main_example*
cover_letters/cover_*
# Legacy output/ subdirs (kept for compatibility)
cv/output/*
!cv/output/.gitkeep
cover_letters/output/*
!cover_letters/output/.gitkeep

# ── Agent state (layout-fix memory cache — REQ-2055 / data-req §16) ────────────
.agents/state/

# ── Upskill reports (generated, personal) ─────────────────────────────────────
upskill/*
!upskill/.gitkeep

# ── Source personal documents (uploaded by user during /setup) ────────────────
documents/cv/*
!documents/cv/.gitkeep
documents/linkedin/*
!documents/linkedin/.gitkeep
documents/diplomas/*
!documents/diplomas/.gitkeep
documents/references/*
!documents/references/.gitkeep
documents/applications/*
!documents/applications/.gitkeep

# ── LaTeX build artefacts ─────────────────────────────────────────────────────
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)
*.bbl
*.blg

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# ── Node / Bun (portal adapters) ──────────────────────────────────────────────
node_modules/
.pnpm-store/
bun.lockb
*.tsbuildinfo

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
