# =============================================================================
# CareerForge .gitignore
# Personal data, generated outputs, and build artefacts must never be committed.
# =============================================================================

# ── Private research (competitive analysis — never commit) ────────────────────
.reference/

# ── Candidate profile content (populated by /setup — personal data) ───────────
# The SKILL.md orchestrator file IS tracked; only the filled-in profile files are not.
.claude/skills/job-application-assistant/01-candidate-profile.md
.claude/skills/job-application-assistant/02-behavioral-profile.md
.claude/skills/job-application-assistant/03-writing-style.md
.claude/skills/job-application-assistant/04-job-evaluation.md
.claude/skills/job-application-assistant/05-cv-templates.md
.claude/skills/job-application-assistant/06-cover-letter-templates.md
.claude/skills/job-application-assistant/07-interview-prep.md

# ── Application state (personal — changes per user) ───────────────────────────
job_search_tracker.csv
job_scraper/seen_jobs.json

# ── Salary data (user-provided, sensitive) ────────────────────────────────────
salary_data.json

# ── Generated documents (CV + cover letter outputs) ───────────────────────────
cv/output/
cover_letters/output/

# ── Upskill reports (generated, personal) ─────────────────────────────────────
upskill/

# ── Source personal documents (uploaded by user during /setup) ────────────────
documents/cv/
documents/linkedin/
documents/diplomas/
documents/references/
documents/applications/

# ── LaTeX build artefacts ─────────────────────────────────────────────────────
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)
*.bbl
*.blg

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# ── Node / Bun (portal adapters) ──────────────────────────────────────────────
node_modules/
.pnpm-store/
bun.lockb
*.tsbuildinfo

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
